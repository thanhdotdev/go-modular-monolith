APP_NAME=project-example
GIN_MODE=debug
HTTP_PORT=8080
DATABASE_DSN=
DATABASE_MIGRATIONS_DIR=migrations

LOG_OUTPUT=both
LOG_FILE_PATH=logs/app.log
LOG_SERVICE_NAME=project-example
LOG_LEVEL=info
LOG_FORMAT=json
LOG_INCLUDE_REQUEST_BODY=false
LOG_INCLUDE_RESPONSE_BODY=false
LOG_BODY_MAX_BYTES=4096
LOG_MAX_SIZE_MB=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE_DAYS=7
LOG_COMPRESS=false
